{
  "name": "openclaw-nango-integrations",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.22.2"
  },
  "scripts": {
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run test/yandex-mail.test.ts test/amocrm-chats-channel.test.ts test/assert-nango-compile.test.ts",
    "test:e2e": "vitest run test/end-to-end.test.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:e2e": "tsc -p tsconfig.e2e.json --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "compile:nango": "nango compile --no-dependency-update --no-telemetry --no-interactive",
    "verify:nango": "npm run compile:nango && node test/assert-nango-compile.mjs"
  },
  "dependencies": {
    "nango": "0.71.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "js-yaml": "4.3.0"
  }
}
