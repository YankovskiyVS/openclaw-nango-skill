{
  "name": "openclaw-nango-integrations",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.22.2"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "compile:nango": "nango compile --no-dependency-update --no-telemetry --no-interactive",
    "verify:nango": "npm run compile:nango && node test/assert-nango-compile.mjs"
  },
  "dependencies": {
    "nango": "0.71.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "js-yaml": "4.3.0"
  }
}
